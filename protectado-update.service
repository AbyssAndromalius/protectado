[Unit]
Description=Protectado — mise à jour depuis git
After=network-online.target

[Service]
Type=oneshot
ExecStart=/usr/local/sbin/protectado-update
ExecStartPost=/bin/rm -f __WORKDIR__/data/update.trigger
StandardOutput=file:__WORKDIR__/data/update.log
StandardError=file:__WORKDIR__/data/update.log
